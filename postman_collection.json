  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set default baseUrl if not defined",
          "if (!pm.variables.get('baseUrl')) {",
          "  pm.variables.set('baseUrl', 'http://localhost:3000');",
          "}",
          "if (!pm.variables.get('quizCode')) {",
          "  pm.variables.set('quizCode', 'demoQuiz');",
          "}"
        ]
      }
    }
  ]
