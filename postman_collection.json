    {
      "name": "Create Quiz Question",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"What is 2 + 2?\",\n  \"options\": [\n    { \"text\": \"3\", \"isCorrect\": false },\n    { \"text\": \"4\", \"isCorrect\": true },\n    { \"text\": \"5\", \"isCorrect\": false }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/quiz/{{quizCode}}/questions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "quiz", "{{quizCode}}", "questions"]
        }
      },
      "response": []
