              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"12345678\",\n  \"cpassword\": \"12345678\",\n  \"gender\": \"male\",\n  \"age\": 25,\n  \"phone\": \"+1234567890\",\n  \"bio\": \"Test account\",\n  \"DOB\": \"1999-01-01\",\n  \"role\": \"user\"\n}",
              "options": {
